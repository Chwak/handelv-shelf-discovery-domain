{
  "name": "shelf-discovery-domain",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "build": "tsc",
    "watch": "tsc -w",
    "cdk": "cdk",
    "deploy": "cdk deploy",
    "diff": "cdk diff",
    "synth": "cdk synth",
    "destroy": "cdk destroy",
    "audit:deps": "npm audit",
    "audit:deps:runtime": "npm audit --omit=dev",
    "audit:deps:ci": "npm audit --audit-level=moderate",
    "test": "bash ../scripts/run-domain-test-files.sh",
    "test:unit": "bash ../scripts/run-domain-test-files.sh units",
    "test:integration": "bash ../scripts/run-domain-test-files.sh lambdas",
    "test:matrix": "node ../scripts/domain-test-matrix.mjs"
  },
  "dependencies": {
    "@aws-sdk/client-dynamodb": "^3.0.0",
    "@aws-sdk/client-eventbridge": "^3.0.0",
    "@aws-sdk/client-glue": "^3.0.0",
    "@aws-sdk/lib-dynamodb": "^3.0.0",
    "ajv": "^8.17.1",
    "ajv-formats": "^2.1.1",
    "aws-cdk-lib": "^2.170.0",
    "constructs": "^10.4.2",
    "source-map-support": "^0.5.21"
  },
  "devDependencies": {
    "@types/aws-lambda": "^8.10.160",
    "@types/node": "^22.10.0",
    "aws-cdk": "^2.170.0",
    "esbuild": "^0.24.0",
    "typescript": "~5.7.0",
    "tsx": "^4.21.0",
    "aws-sdk-client-mock": "^4.1.0"
  }
}
